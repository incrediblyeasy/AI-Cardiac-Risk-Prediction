{
  "data": {
    "batch_size": 16,
    "oversample": true,
    "normalize": true,
    "num_workers": 0,
    "data_dir": null,
    "train_records": [101, 106],
    "test_records": [100, 103]
  },
  "model": {
    "n_classes": 5,
    "widths": [16, 32, 64, 128, 128],
    "fusion_hidden": 64,
    "dropout": 0.3
  },
  "optim": {
    "name": "adamw",
    "lr": 0.001,
    "weight_decay": 0.0001,
    "momentum": 0.9,
    "scheduler": "cosine",
    "step_size": 10,
    "gamma": 0.1,
    "min_lr": 1e-05
  },
  "train": {
    "epochs": 2,
    "device": "auto",
    "seed": 0,
    "class_weighted_loss": false,
    "label_smoothing": 0.0,
    "grad_clip": 5.0,
    "out_dir": "runs/echofusenet_smoke",
    "checkpoint_metric": "macro_f1",
    "log_interval": 20,
    "tensorboard": false
  }
}
